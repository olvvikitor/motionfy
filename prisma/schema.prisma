generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String             @id @default(uuid())
  email        String?
  password     String?
  accessToken  String?
  refreshToken String?
  country      String
  provider     String
  display_name String
  img_profile  String
  notificateEmail Boolean @default(false)
  notificatePush Boolean @default(false)
  notificateWeek Boolean @default(false)
  @@unique([email, provider])

  histories    ListeningHistory[]
  moodAnalyses MoodAnalysis[]

  sentFriendRequests     Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Track {
  id        String             @id @default(uuid())
  spotifyId String?            @unique
  title     String
  artist    String
  album     String?
  img_url   String?
  createdAt DateTime           @default(now())
  histories ListeningHistory[]
}

model MoodAnalysis {
  id              String   @id @default(uuid())
  moodScore       Float
  sentiment       String
  coreAxes Json
  emotions        Json
  analyzedAt      DateTime @default(now())
  tracksAnalyzeds Json
  userId          String
  user            User     @relation(fields: [userId], references: [id])
}

model ListeningHistory {
  id       String   @id @default(uuid())
  userId   String
  trackId  String
  playedAt DateTime
  track    Track    @relation(fields: [trackId], references: [spotifyId])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, trackId, playedAt])
}
