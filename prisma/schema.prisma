generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String  @id @default(uuid())
  email           String?
  password        String?
  accessToken     String?
  refreshToken    String?
  country         String
  provider        String
  display_name    String
  img_profile     String
  face_photo_path String?
  image_credits   Int     @default(1)
  notificateEmail Boolean @default(false)
  notificatePush  Boolean @default(false)
  notificateWeek  Boolean @default(false)

  histories    ListeningHistory[]
  moodAnalyses MoodAnalysis[]
  creditLogs   CreditLog[]

  sentFriendRequests     Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")

  @@unique([email, provider])
}

model CreditLog {
  id        String          @id @default(uuid())
  userId    String
  type      CreditLogType
  amount    Int
  note      String?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum CreditLogType {
  PURCHASE
  CONSUME
  BONUS
  REFUND
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Track {
  id        String             @id @default(uuid())
  spotifyId String?            @unique
  title     String
  artist    String
  album     String?
  img_url   String?
  createdAt DateTime           @default(now())
  histories ListeningHistory[]
}

model TracksAnalysis {
  id                String   @unique @default(uuid())
  spotifyid         String   @unique
  moodScore         Float
  dominantSentiment String
  coreAxes          Json
  emotionalVector   Json
  reasoning         String
  analyzedAt        DateTime @default(now())
}

model MoodAnalysis {
  id              String   @id @default(uuid())
  moodScore       Float
  sentiment       String
  image_mood      String?
  coreAxes        Json
  emotions        Json
  analyzedAt      DateTime @default(now())
  tracksAnalyzeds Json
  userId          String
  user            User     @relation(fields: [userId], references: [id])
}

model ListeningHistory {
  id       String   @id @default(uuid())
  userId   String
  trackId  String
  playedAt DateTime
  track    Track    @relation(fields: [trackId], references: [spotifyId])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, trackId, playedAt])
}
